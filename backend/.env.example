# Database configuration (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/agrisense

# Auth secret key (change in production)
SECRET_KEY=change-this-to-a-very-secure-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI/Inference Settings
UPLOAD_DIR=uploads
